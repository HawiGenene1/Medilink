# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
# Local:   mongodb://127.0.0.1:27017/medilink
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/medilink?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/medilink

# JWT Configuration
# Use a long random string in production (e.g. openssl rand -hex 64)
JWT_SECRET=change_this_to_a_strong_random_secret
JWT_EXPIRE=7d

# CORS - comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app

# Chapa Payment Configuration
CHAPA_SECRET_KEY=your_chapa_secret_key_here
CHAPA_BASE_URL=https://api.chapa.co/v1
